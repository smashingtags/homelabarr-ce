# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (keep only .env.example and .env.ecosystem)
.env
.env.*
!.env.example
!.env.ecosystem
*/.env
*/.env.*
!*/.env.example
!*/.env.test

# Build outputs
dist/
build/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Claude settings (user-specific)
.claude/settings.local.json

# Logs
*.log
logs/

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Docker volumes
volumes/

# Temporary files
tmp/
temp/
server/config/users.json
server/data/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

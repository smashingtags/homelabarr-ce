# homelabarr-cli Local Mode Environment Configuration
# Copy this file to .env and customize for your setup

# Core Settings
ID=1000                           # User ID for file permissions
TZ=America/New_York              # Your timezone
UMASK=002                        # File creation permissions mask
RESTARTAPP=unless-stopped        # Container restart policy
SECURITYOPS=no-new-privileges    # Security option
SECURITYOPSSET=true             # Enable security options

# Application Data Path
APPFOLDER=/opt/appdata          # Where app configs are stored

# Container Images - Core Services (Latest versions)
PLEXIMAGE=lscr.io/linuxserver/plex:latest
RADARRIMAGE=lscr.io/linuxserver/radarr:latest
SONARRIMAGE=lscr.io/linuxserver/sonarr:latest
QBITORRENTIMAGE=lscr.io/linuxserver/qbittorrent:latest

# Container Images - Additional Services
JELLYFINIMAGE=lscr.io/linuxserver/jellyfin:latest
OVERSEERRIMAGE=lscr.io/linuxserver/overseerr:latest
SABNZBDIMAGE=lscr.io/linuxserver/sabnzbd:latest
TAUTULLIIMAGE=lscr.io/linuxserver/tautulli:latest

# Plex Configuration
PLEXVERSION=docker              # Plex version (use 'docker' for latest)
PLEXTHEME=dark                 # Theme: dark, plex, space-gray, aquamarine, etc.
PLEXADDON=                     # Additional Plex addons (optional)

# Theme Configuration - Core Services
RADARRTHEME=dark               # Radarr theme
SONARRTHEME=dark               # Sonarr theme
QBITORRENTTHEME=dark          # qBittorrent theme

# Theme Configuration - Additional Services
JELLYFINTHEME=dark             # Jellyfin theme
OVERSEERRTHEME=dark           # Overseerr theme
SABNZBDTHEME=dark             # SABnzbd theme
TAUTULLITHEME=dark            # Tautulli theme

# Mount Enhanced Configuration
MOUNT_ENHANCED_IMAGE=ghcr.io/smashingtags/homelabarr-mount-enhanced:latest
MOUNT_ENHANCED_WEB_PORT=8190
MOUNT_ENHANCED_METRICS_PORT=9190

# Enhanced Storage Settings
GDRIVE_ENABLED=true
BACKBLAZE_ENABLED=false
ONEDRIVE_ENABLED=false
PCLOUD_ENABLED=false
UPLOAD_CONCURRENCY=4
VFS_CACHE_MODE=writes
VFS_CACHE_SIZE=100GB
BUFFER_SIZE=48M
COST_LIMIT_MONTHLY=50
PROVIDER_SELECTION=auto
COST_ALERTS=enabled
WEB_UI=enabled
METRICS_ENABLED=true
LOG_LEVEL=INFO

# Optional Settings
# PLEX_CLAIM=claim-xxxxxxxxx   # Get from https://plex.tv/claim
# APPFOLDER=./test-data        # Use for testing in current directory
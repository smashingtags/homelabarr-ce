# N8N MCP Server Configuration
# Generate a secure token for MCP client authentication
N8N_MCP_AUTH_TOKEN=REDACTED_MCP_TOKEN

# N8N API Configuration (connect to your n8n instance)
N8N_API_URL=http://192.168.1.x:5678
N8N_API_KEY=REDACTED_N8N_API_KEY

# Standard HomelabARR variables
PUID=1000
PGID=1000
TZ=America/New_York
APPDATA_PATH=/opt/appdata
DOMAIN=example.com
LOG_LEVEL=info
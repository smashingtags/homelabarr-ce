# Test Environment Variables for HomelabARR CLI
DOMAIN=localhost.local
ID=1000
TZ=America/New_York
UMASK=002
RESTARTAPP=unless-stopped
SECURITYOPS=no-new-privileges
SECURITYOPSSET=true
APPFOLDER=/opt/appdata
YACHT_PORT=8080
DOCKERNETWORK=proxy

# Plex specific
PLEXVERSION=latest
PLEXTHEME=dark
PLEXADDON=none
PLEXIMAGE=linuxserver/plex:latest

# Other app variables
CLOUDCMD_PORT=8214

# Portainer specific
PORTAINERIMAGE=portainer/portainer-ce:latest

# Jellyfin specific
JELLYFINIMAGE=jellyfin/jellyfin:latest
JELLYFIN_PORT=8096
JELLYFINTHEME=dark

# Radarr specific
RADARRIMAGE=lscr.io/linuxserver/radarr:latest
RADARRTHEME=dark
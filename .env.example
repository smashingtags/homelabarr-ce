# HomelabARR CE Environment Configuration
# Copy this file to .env and fill in your values.
# The quick-start install sets these automatically — only edit if you need to change them.

# ─── Required ────────────────────────────────────────────────────────────────

# Keeps your login sessions secure. Generate one with: openssl rand -base64 32
JWT_SECRET=change-me-generate-with-openssl

# The GID of the docker group on your host. Find it with: getent group docker | cut -d: -f3
DOCKER_GID=999

# The URL you open the dashboard at — must match exactly or login won't work.
# Example: http://192.168.1.100:8084
CORS_ORIGIN=http://your-server-ip:8084

# ─── Recommended ─────────────────────────────────────────────────────────────

# Override the default admin password (default is "admin" — change this before exposing to a network)
DEFAULT_ADMIN_PASSWORD=changeme

# Where HomelabARR CE lives on your host.
CLI_BRIDGE_HOST_PATH=/opt/homelabarr

# Where the community app templates live on your host.
# Clone: git clone https://github.com/smashingtags/homelabarr-templates.git /opt/homelabarr/templates
TEMPLATES_HOST_PATH=/opt/homelabarr/templates

# ─── Optional ─────────────────────────────────────────────────────────────────

# Your timezone. Used by apps that need it.
TZ=America/New_York

# Backend API port (default: 8092)
# PORT=8092

# Set to "true" to disable authentication entirely (local/trusted network only)
# AUTH_ENABLED=true

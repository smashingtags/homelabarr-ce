# HomelabARR CLI Environment Configuration
# Copy this file to .env and update with your values

# User and Group IDs
PUID=1000
PGID=1000

# Timezone
TZ=America/New_York

# Paths
USERDIR=/opt/homelabarr
DOCKERDIR=/opt/homelabarr/apps
DATADIR=/opt/homelabarr/data
MEDIADIR=/media

# For Full Mode with Traefik (optional)
DOMAIN=example.com
CLOUDFLARE_EMAIL=your-email@example.com
CLOUDFLARE_API_KEY=your-cloudflare-api-key
AUTHELIA_JWT_SECRET=your-jwt-secret
AUTHELIA_SESSION_SECRET=your-session-secret

# Database (if using centralized DB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=homelabarr
DB_PASS=changeme
DB_NAME=homelabarr

# VPN (optional)
VPN_SERVICE_PROVIDER=your-vpn-provider
VPN_USER=your-vpn-username
VPN_PASS=your-vpn-password

# Plex (optional)
PLEX_CLAIM=claim-token-from-plex.tv
PLEX_ADVERTISE_IP=http://your-server-ip:32400/

# Media Server Ports (for local mode)
PLEX_PORT=32400
JELLYFIN_PORT=8096
EMBY_PORT=8097
# Uploader Service Versions
UPLOADER_VERSION=4.2.0  # Latest stable version of homelabarr-uploader
MOUNT_VERSION=latest    # Mount-enhanced service version

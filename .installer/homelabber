#!/bin/bash

# HomelabARR CE — CLI wrapper
# Installed to /usr/local/bin/homelabarr-cli by install-remote.sh

HOMELABARR_DIR="/opt/homelabarr"

if [ "$EUID" -ne 0 ]; then
  sudo "$0" "$@"
  exit $?
fi

if [ ! -d "$HOMELABARR_DIR" ]; then
  echo "⛔ HomelabARR not found at $HOMELABARR_DIR"
  echo "   Install: git clone https://github.com/smashingtags/homelabarr-ce.git $HOMELABARR_DIR"
  exit 1
fi

usage() {
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "    🚀 HomelabARR CE CLI"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "    homelabarr-cli -i, --install    Open the setup menu"
  echo "    homelabarr-cli -h, --help       Show this help"
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
}

case "${1:-}" in
  ""|-i|--install)
    cd "$HOMELABARR_DIR" && bash install.sh
    ;;
  -h|--help)
    usage
    ;;
  *)
    echo "Unknown option: $1"
    usage
    exit 1
    ;;
esac
